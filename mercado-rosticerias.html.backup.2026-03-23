<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Análisis de Competidores — Ricki Pollo | Mercado Rosticerias Puebla</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #f8f9fb;
      color: #1a1a2e;
      line-height: 1.6;
    }

    /* HEADER */
    .header {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
      color: white;
      padding: 48px 40px 36px;
      position: relative;
      overflow: hidden;
    }
    .header::after {
      content: '';
      position: absolute;
      bottom: -30px; left: 0; right: 0;
      height: 60px;
      background: #f8f9fb;
      clip-path: ellipse(55% 100% at 50% 100%);
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 16px;
    }
    .header h1 {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      line-height: 1.2;
    }
    .header h1 span { color: #f39c12; }
    .header p { margin-top: 8px; opacity: 0.75; font-size: 0.95rem; }
    .header-meta { text-align: right; }
    .header-meta .date { font-size: 0.85rem; opacity: 0.65; }
    .powered {
      display: inline-block;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 0.78rem;
      font-weight: 500;
      margin-top: 8px;
      letter-spacing: 0.3px;
    }
    .powered span { color: #f39c12; }

    /* CONTAINER */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 60px 24px 80px;
    }

    /* ===== LEÑA HERO SECTION ===== */
    .lena-hero {
      background: linear-gradient(135deg, #3d1a00 0%, #6b2a00 40%, #8b3a00 100%);
      border-radius: 20px;
      padding: 36px 40px;
      margin-bottom: 52px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(61,26,0,0.35);
    }
    .lena-hero::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(243,156,18,0.12);
    }
    .lena-hero::after {
      content: '';
      position: absolute;
      bottom: -60px; left: -30px;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .lena-hero-inner {
      display: flex;
      gap: 28px;
      align-items: flex-start;
      position: relative;
      z-index: 1;
    }
    .lena-flame {
      font-size: 4rem;
      line-height: 1;
      flex-shrink: 0;
      filter: drop-shadow(0 0 12px rgba(243,156,18,0.6));
    }
    .lena-content { flex: 1; }
    .lena-content h2 {
      font-size: 1.6rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 4px;
      line-height: 1.2;
    }
    .lena-sub {
      font-size: 1.1rem;
      color: #f39c12;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .lena-desc {
      color: rgba(255,255,255,0.7);
      font-size: 0.9rem;
      margin-bottom: 16px;
    }
    .lena-points {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .lena-point {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(243,156,18,0.25);
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 0.86rem;
      color: rgba(255,255,255,0.9);
      line-height: 1.4;
    }
    .lena-point strong { color: #f39c12; }

    /* SECTION TITLE */
    .section-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 28px;
      padding-bottom: 12px;
      border-bottom: 3px solid #f39c12;
      display: inline-block;
    }

    /* COMPETITOR GRID */
    .competitors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
      gap: 32px;
      margin-bottom: 72px;
    }

    /* COMPETITOR CARD */
    .card {
      background: #ffffff;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(26,26,46,0.08), 0 1px 3px rgba(26,26,46,0.04);
      overflow: hidden;
      transition: box-shadow 0.2s;
    }
    .card:hover {
      box-shadow: 0 8px 32px rgba(26,26,46,0.14), 0 2px 8px rgba(26,26,46,0.06);
    }

    .card-header {
      padding: 20px 24px 16px;
      border-bottom: 1px solid #f0f0f5;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }
    .card-title { font-size: 1.15rem; font-weight: 700; color: #1a1a2e; }
    .card-address { font-size: 0.82rem; color: #888; margin-top: 4px; }

    .rating-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .rating-green { background: #d4f5e3; color: #1a8c50; }
    .rating-yellow { background: #fef3cd; color: #9a6200; }
    .rating-red { background: #fde8e8; color: #c0392b; }

    /* PHOTO WRAPPER */
    .photo-wrapper {
      position: relative;
      width: 100%;
      height: 200px;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      overflow: hidden;
    }
    .photo-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .photo-maps-link {
      position: absolute;
      bottom: 8px;
      right: 8px;
      background: rgba(255,255,255,0.92);
      border-radius: 8px;
      padding: 4px 10px;
      font-size: 0.72rem;
      font-weight: 600;
      color: #1a1a2e;
      text-decoration: none;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    .photo-maps-link:hover { background: #fff; }
    .photo-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #999;
      font-size: 0.85rem;
      gap: 8px;
    }
    .photo-placeholder span:first-child { font-size: 2rem; }

    /* CARD BODY */
    .card-body { padding: 20px 24px; }

    .info-row {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
      font-size: 0.87rem;
      align-items: flex-start;
    }
    .info-icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
    .info-label { font-weight: 600; color: #555; margin-right: 4px; }

    /* PLATFORMS */
    .platforms { display: flex; flex-wrap: wrap; gap: 6px; margin: 12px 0 16px; }
    .platform-badge {
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.3px;
    }
    .p-uber { background: #06C167; color: white; }
    .p-rappi { background: #FF441F; color: white; }
    .p-didi { background: #FF5C00; color: white; }
    .p-none { background: #e5e7eb; color: #6b7280; font-style: italic; font-weight: 500; }

    /* REVIEWS */
    .reviews { margin: 14px 0; }
    .review {
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 0.83rem;
      line-height: 1.5;
      margin-bottom: 8px;
    }
    .review-pos { background: #f0faf5; border-left: 3px solid #2ecc71; color: #1d5c38; }
    .review-neg { background: #fff5f5; border-left: 3px solid #e74c3c; color: #7b1e1e; }
    .review-neu { background: #f5f5f5; border-left: 3px solid #bbb; color: #555; }

    /* STRENGTHS/WEAKNESSES */
    .sw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
    .sw-box { border-radius: 10px; padding: 12px 14px; font-size: 0.83rem; line-height: 1.5; }
    .sw-strong { background: #f0faf5; border: 1px solid #b6f0d0; }
    .sw-strong .sw-label { color: #1a8c50; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .sw-weak { background: #fff5f5; border: 1px solid #f5c0c0; }
    .sw-weak .sw-label { color: #c0392b; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .sw-box p { color: #444; }

    /* DIVIDER */
    .divider { height: 1px; background: #f0f0f5; margin: 16px 0; }

    /* OPPORTUNITIES SECTION */
    .opportunities { margin-top: 16px; }
    .opp-title {
      font-size: 1.5rem;
      font-weight: 800;
      color: #1a1a2e;
      margin-bottom: 8px;
    }
    .opp-subtitle { color: #666; margin-bottom: 32px; font-size: 0.95rem; }

    .opp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 20px; }
    .opp-card {
      background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
      color: white;
      border-radius: 14px;
      padding: 24px 20px;
      position: relative;
      overflow: hidden;
    }
    .opp-card::before {
      content: '';
      position: absolute;
      top: -20px; right: -20px;
      width: 80px; height: 80px;
      border-radius: 50%;
      background: rgba(243,156,18,0.15);
    }
    .opp-num {
      font-size: 2rem;
      font-weight: 800;
      color: #f39c12;
      line-height: 1;
      margin-bottom: 10px;
    }
    .opp-label {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #f39c12;
      margin-bottom: 6px;
    }
    .opp-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
    .opp-card p { font-size: 0.83rem; opacity: 0.8; line-height: 1.5; }

    /* ===== VENTAJA COMPETITIVA TABLE ===== */
    .ventaja-section {
      margin-top: 64px;
    }
    .table-wrapper {
      overflow-x: auto;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(26,26,46,0.08);
      margin-top: 28px;
    }
    .comp-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      font-size: 0.88rem;
    }
    .comp-table thead th {
      padding: 16px 20px;
      text-align: left;
      font-weight: 700;
      font-size: 0.85rem;
      background: #1a1a2e;
      color: rgba(255,255,255,0.7);
      border-bottom: 2px solid #f39c12;
    }
    .comp-table thead th:first-child { border-radius: 16px 0 0 0; }
    .comp-table thead th:last-child { border-radius: 0 16px 0 0; }
    .comp-table thead th.col-ricki {
      background: linear-gradient(135deg, #3d1a00, #6b2a00);
      color: #f39c12;
    }
    .comp-table tbody tr { border-bottom: 1px solid #f0f0f5; }
    .comp-table tbody tr:hover { background: #f8f9fb; }
    .comp-table tbody td {
      padding: 14px 20px;
      color: #333;
      vertical-align: middle;
    }
    .comp-table tbody td:first-child {
      font-weight: 600;
      color: #1a1a2e;
      background: #fafafa;
    }
    .comp-table tbody td.col-ricki {
      background: linear-gradient(90deg, #fff8f0, #fff);
      font-weight: 700;
      color: #6b2a00;
    }
    .comp-table tbody tr:last-child td:first-child { border-radius: 0 0 0 16px; }
    .comp-table tbody tr:last-child td:last-child { border-radius: 0 0 16px 0; }
    .win-badge {
      display: inline-block;
      background: #f39c12;
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 8px;
      margin-left: 6px;
      vertical-align: middle;
    }

    /* FOOTER */
    .footer {
      background: #1a1a2e;
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 24px;
      font-size: 0.8rem;
    }
    .footer strong { color: #f39c12; }

    /* ===== PRICE COMPARISON SECTION ===== */
    .precios-section { margin-top: 72px; }
    .precios-intro {
      background: linear-gradient(135deg, #6b2a00 0%, #b4532a 100%);
      border-radius: 16px;
      padding: 24px 32px;
      margin-bottom: 36px;
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .precios-intro-icon { font-size: 2.8rem; flex-shrink: 0; }
    .precios-intro-text h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .precios-intro-text p { font-size: 0.88rem; color: rgba(255,255,255,0.75); }
    .premium-note {
      background: #fff8f0;
      border: 2px solid #b4532a;
      border-radius: 12px;
      padding: 12px 20px;
      font-size: 0.88rem;
      color: #6b2a00;
      font-weight: 600;
      margin-top: -12px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .premium-note-icon { font-size: 1.4rem; flex-shrink: 0; }

    /* Price Table */
    .price-table-wrapper {
      overflow-x: auto;
      border-radius: 16px;
      box-shadow: 0 2px 16px rgba(26,26,46,0.1);
      margin-bottom: 40px;
    }
    .price-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      font-size: 0.88rem;
    }
    .price-table thead th {
      padding: 16px 20px;
      text-align: left;
      font-weight: 700;
      font-size: 0.84rem;
      letter-spacing: 0.3px;
    }
    .price-table thead th:first-child { background: #1a1a2e; color: rgba(255,255,255,0.65); border-radius: 16px 0 0 0; }
    .price-table thead .th-ricki { background: linear-gradient(135deg, #6b2a00, #b4532a); color: #ffe0cc; }
    .price-table thead .th-feliz { background: #c0392b; color: #ffe5e5; }
    .price-table thead .th-sabornis { background: #555; color: #e0e0e0; border-radius: 0 16px 0 0; }
    .price-table tbody tr { border-bottom: 1px solid #f0f0f5; }
    .price-table tbody tr:hover { background: #fafafa; }
    .price-table tbody td {
      padding: 14px 20px;
      color: #333;
      vertical-align: middle;
    }
    .price-table tbody td:first-child { font-weight: 600; color: #1a1a2e; background: #fafafa; }
    .price-table .td-ricki {
      font-weight: 700;
      color: #6b2a00;
      background: linear-gradient(90deg, #fff3ec, #fff);
    }
    .price-table .td-feliz { color: #c0392b; }
    .price-table .td-sabornis { color: #555; }
    .best-badge {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 8px;
      margin-left: 6px;
      vertical-align: middle;
    }
    .badge-win { background: #b4532a; color: white; }
    .badge-nd { background: #e5e7eb; color: #9ca3af; }

    /* Bar chart visual */
    .price-bars-section {
      background: white;
      border-radius: 16px;
      padding: 28px 32px;
      box-shadow: 0 2px 12px rgba(26,26,46,0.08);
      margin-bottom: 40px;
    }
    .price-bars-section h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 24px;
    }
    .bar-group { margin-bottom: 20px; }
    .bar-group-label {
      font-size: 0.88rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 10px;
    }
    .bar-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 7px;
    }
    .bar-brand-label { width: 110px; font-size: 0.79rem; font-weight: 600; flex-shrink: 0; }
    .bar-track { flex: 1; background: #f0f0f5; border-radius: 20px; height: 26px; overflow: hidden; }
    .bar-fill {
      height: 100%;
      border-radius: 20px;
      display: flex;
      align-items: center;
      padding: 0 12px;
      font-size: 0.76rem;
      font-weight: 700;
      color: white;
      white-space: nowrap;
      transition: width 0.3s ease;
    }
    .bar-ricki { background: linear-gradient(90deg, #b4532a, #d4692e); }
    .bar-feliz { background: #c0392b; }
    .bar-sabornis { background: #777; }

    /* Complementos section */
    .complementos-section {
      background: linear-gradient(135deg, #fff8f4 0%, #fff 100%);
      border: 2px solid #e8c4ae;
      border-radius: 16px;
      padding: 28px 32px;
      margin-bottom: 40px;
    }
    .complementos-section h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #6b2a00;
      margin-bottom: 6px;
    }
    .complementos-section .comp-subtitle {
      font-size: 0.84rem;
      color: #888;
      margin-bottom: 20px;
    }
    .comp-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }
    .comp-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: white;
      border: 1px solid #f0dbd0;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 0.85rem;
    }
    .comp-name { color: #333; font-weight: 500; }
    .comp-price { font-weight: 800; color: #b4532a; }

    @media (max-width: 700px) {
      .lena-hero-inner { flex-direction: column; gap: 16px; }
      .lena-points { grid-template-columns: 1fr; }
      .lena-flame { font-size: 3rem; }
      .competitors-grid { grid-template-columns: 1fr; }
      .sw-grid { grid-template-columns: 1fr; }
      .header h1 { font-size: 1.5rem; }
      .opp-grid { grid-template-columns: 1fr 1fr; }
      .lena-hero { padding: 24px 20px; }
      .comp-grid { grid-template-columns: 1fr 1fr; }
      .bar-brand-label { width: 80px; }
      .complementos-section, .price-bars-section { padding: 20px; }
    }
  </style>
</head>
<body>

<header class="header">
  <div class="header-inner">
    <div>
      <h1>Mercado de <span>Rosticerias</span><br>Puebla / Cholula</h1>
      <p>Análisis competitivo para <strong style="color:#fff">Ricki Pollo</strong> — 5 competidores identificados</p>
    </div>
    <div class="header-meta">
      <div class="date">📅 Marzo 2026</div>
      <div class="powered">Powered by <span>AgentX</span></div>
    </div>
  </div>
</header>

<div class="container">

  <!-- ===== LEÑA HERO ===== -->
  <div class="lena-hero">
    <div class="lena-hero-inner">
      <div class="lena-flame">🔥</div>
      <div class="lena-content">
        <h2>¿Por qué Ricki Pollo?</h2>
        <p class="lena-sub">La diferencia está en la leña</p>
        <p class="lena-desc">Mientras todos usan gas o pollos industriales:</p>
        <div class="lena-points">
          <div class="lena-point">✅ <strong>Leña auténtica</strong> — sabor ahumado real, no artificial</div>
          <div class="lena-point">✅ <strong>Cocción lenta tradicional a la leña</strong> — jugosidad garantizada</div>
          <div class="lena-point">✅ <strong>Receta artesanal</strong> — sin químicos ni conservadores</div>
          <div class="lena-point">✅ <strong>Precio premium accesible</strong> — mejor que Sabornis ($335) con más tradición</div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-title">🐔 Competidores Directos</div>

  <div class="competitors-grid">

    <!-- 1. Pollo Feliz Zavaleta -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Pollo Feliz Zavaleta</div>
          <div class="card-address">📍 Calz. Zavaleta 98, Zavaleta, Puebla</div>
        </div>
        <div>
          <span class="rating-badge rating-yellow">⭐ 4.3 Google</span><br>
          <span class="rating-badge rating-green" style="margin-top:4px">⭐ 4.8 UE</span>
        </div>
      </div>
      <div class="photo-wrapper">
        <img
          alt="Pollo Feliz Zavaleta"
          onerror="this.outerHTML='<div class=\'photo-placeholder\'><span>🍗</span><span>Pollo Feliz Zavaleta</span></div>'"
        />
        <a class="photo-maps-link" href="https://maps.google.com/?q=Calzada+Zavaleta+98+Puebla" target="_blank">📍 Ver en Maps</a>
      </div>
      <div class="card-body">
        <div class="info-row"><span class="info-icon">🕐</span><span><span class="info-label">Horario:</span> Lun–Dom: 12:01 PM – 6:45 PM</span></div>
        <div class="info-row"><span class="info-icon">💰</span><span><span class="info-label">Precio:</span> No publicado oficialmente</span></div>
        <div class="platforms">
          <span class="platform-badge p-uber">Uber Eats</span>
          <span class="platform-badge p-rappi">Rappi</span>
        </div>
        <div class="divider"></div>
        <div class="reviews">
