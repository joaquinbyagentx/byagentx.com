        "pricing.p3.f3":"Análisis de Engagement",
        "pricing.p3.f4":"Optimización de Hashtags",
        "pricing.p3.f5":"Calendario de Contenido Mensual",
        "pricing.p3.cta":"Comenzar →",
        "pricing.p3.industry":"<strong>Industria promedio:</strong> $25,000/mes — <strong style='color: #22c55e;'>Ahorras 46%</strong>",
        "pricing.p4.name":"SEO + Contenido AI",
        "pricing.p4.desc":"Optimización de motores de búsqueda + estrategia de contenido AI.",
        "pricing.p4.f1":"Auditoría y Estrategia SEO",
        "pricing.p4.f2":"Posts de Blog AI (4/mes)",
        "pricing.p4.f3":"Investigación de Palabras Clave",
        "pricing.p4.f4":"Estrategia de Backlinks",
        "pricing.p4.f5":"Seguimiento de Posiciones",
        "pricing.p4.cta":"Comenzar →",
        "pricing.p4.industry":"<strong>Industria promedio:</strong> $30,000/mes — <strong style='color: #22c55e;'>Ahorras 43%</strong>",
        "pricing.p5.name":"Automatización Empresarial",
        "pricing.p5.desc":"Flujos AI personalizados para los procesos únicos de tu negocio.",
        "pricing.p5.f1":"Diseño de Flujo Personalizado",
        "pricing.p5.f2":"Integración CRM",
        "pricing.p5.f3":"Automatización de Email",
        "pricing.p5.f4":"Reportes Avanzados",
        "pricing.p5.f5":"Soporte Dedicado",
        "pricing.p5.cta":"Comenzar →",
        "pricing.p5.industry":"<strong>Industria promedio:</strong> $45,000/mes — <strong style='color: #22c55e;'>Ahorras 73%</strong>",
        "pricing.p6.name":"Paquete Completo AI",
        "pricing.p6.desc":"Transformación AI completa: todas las herramientas, todas las características, servicio personalizado.",
        "pricing.p6.f1":"Todo Incluido",
        "pricing.p6.f2":"Flujos AI Personalizados",
        "pricing.p6.f3":"Personalización Ilimitada",
        "pricing.p6.f4":"Soporte Dedicado 24/7",
        "pricing.p6.f5":"Sesiones de Estrategia Mensuales",
        "pricing.p6.cta":"Comenzar →",
        "pricing.p6.industry":"<strong>Industria promedio:</strong> $80,000/mes — <strong style='color: #22c55e;'>Ahorras 72%</strong>",
        "trust.label":   "Testimonios",
        "trust.title":   "La confianza de negocios en todo México",
        "trust.q1":      "\"AgentX automatizó todo nuestro soporte de WhatsApp. Los tiempos de respuesta pasaron de horas a segundos. Los ingresos subieron 40% en 3 meses.\"",
        "trust.r1":      "CEO, Distribuidora Reyes",
        "trust.q2":      "\"Nuestro nuevo sitio convierte 3x mejor que el anterior. El AI se adapta a lo que quieren los visitantes. Se siente como magia.\"",
        "trust.r2":      "Dueña, Boutique Citlali",
        "trust.q3":      "\"Ahorramos más de 40 horas por semana en tareas repetitivas. Mi equipo ahora se enfoca en lo que realmente hace crecer el negocio.\"",
        "trust.r3":      "Director, Grupo Salinas CDMX",
        "cta.label":     "¿Listo para empezar?",
        "cta.title1":    "Tu negocio,",
        "cta.title2":    "en piloto automático",
        "cta.subtitle":  "Sé de los primeros negocios en funcionar con AgentX. Configuración en 72 horas, resultados desde el primer día.",
        "cta.email":     "Escríbenos",
        "cta.see_pricing":"Ver precios",
        "footer.tagline":"Automatización AI para Negocios",
        "footer.rights":"Todos los derechos reservados.",
        "footer.casestudy":"Caso de Estudio",
        "footer.privacy":"Política de Privacidad",
        "footer.terms":"Términos de Servicio",
        "pricing.disclaimer":"*Precios aproximados en pesos mexicanos. Los pagos se procesan en USD mediante Stripe. El cargo final en MXN depende del tipo de cambio de tu banco al momento del pago.",
      }
    };

    /* Prices USD (in cents for Stripe) */
    const USD = {
      p1_setup: 50000, p1_monthly: 15000,
      p2_setup: 150000, p2_monthly: 20000,
      p3_setup: 70000,  p3_monthly: 15000,
      p4_setup: 100000,  p4_monthly: 15000,
      p5_setup: 200000, p5_monthly: 40000,
      p6_setup: 250000, p6_monthly: 50000
    };
    const MXN_RATE = 20;

    let currentLang = localStorage.getItem('agentx-lang') || 'en';

    function applyLang(lang) {
      const dict = T[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (dict[key] !== undefined) el.textContent = dict[key];
      });

      // Apply HTML translations (for industry average boxes)
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        const key = el.getAttribute('data-i18n-html');
        if (dict[key] !== undefined) {
          el.innerHTML = dict[key];
          el.style.display = lang === 'es' ? 'block' : 'none';
        }
      });

      // prices
      if (lang === 'es') {
        // Plan 1
        document.getElementById('price1a').textContent = (USD.p1_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price1b').textContent = (USD.p1_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price1a-mxn').textContent = '~$' + (USD.p1_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price1b-mxn').textContent = '~$' + (USD.p1_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 2
        document.getElementById('price2a').textContent = (USD.p2_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price2b').textContent = (USD.p2_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price2a-mxn').textContent = '~$' + (USD.p2_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price2b-mxn').textContent = '~$' + (USD.p2_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 3
        document.getElementById('price3a').textContent = (USD.p3_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price3a-mxn').textContent = '~$' + (USD.p3_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price3').textContent = (USD.p3_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price3-mxn').textContent = '~$' + (USD.p3_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 4
        document.getElementById('price4a').textContent = (USD.p4_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price4a-mxn').textContent = '~$' + (USD.p4_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price4').textContent = (USD.p4_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price4-mxn').textContent = '~$' + (USD.p4_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 5
        document.getElementById('price5a').textContent = (USD.p5_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price5b').textContent = (USD.p5_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price5a-mxn').textContent = '~$' + (USD.p5_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price5b-mxn').textContent = '~$' + (USD.p5_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 6
        document.getElementById('price6a').textContent = (USD.p6_setup / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price6b').textContent = (USD.p6_monthly / 100 * MXN_RATE).toLocaleString('es-MX');
        document.getElementById('price6a-mxn').textContent = '~$' + (USD.p6_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price6b-mxn').textContent = '~$' + (USD.p6_monthly / 100).toLocaleString('en-US') + ' USD';
      } else {
        // Plan 1 (convert cents to dollars with USD label)
        document.getElementById('price1a').textContent = (USD.p1_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price1b').textContent = (USD.p1_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 2
        document.getElementById('price2a').textContent = (USD.p2_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price2b').textContent = (USD.p2_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 3
        document.getElementById('price3a').textContent = (USD.p3_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price3').textContent = (USD.p3_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 4
        document.getElementById('price4a').textContent = (USD.p4_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price4').textContent = (USD.p4_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 5
        document.getElementById('price5a').textContent = (USD.p5_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price5b').textContent = (USD.p5_monthly / 100).toLocaleString('en-US') + ' USD';
        // Plan 6
        document.getElementById('price6a').textContent = (USD.p6_setup / 100).toLocaleString('en-US') + ' USD';
        document.getElementById('price6b').textContent = (USD.p6_monthly / 100).toLocaleString('en-US') + ' USD';
        // Clear MXN reference divs
        ['price1a-mxn','price1b-mxn','price2a-mxn','price2b-mxn','price3a-mxn','price3-mxn','price4a-mxn','price4-mxn','price5a-mxn','price5b-mxn','price6a-mxn','price6b-mxn'].forEach(function(id) {
          var el = document.getElementById(id); if (el) el.textContent = '';
        });
      }

      // toggle button label
      document.getElementById('langToggle').textContent = lang === 'en' ? 'ES' : 'EN';
      document.documentElement.lang = lang;
    }

    function toggleLanguage() {
      currentLang = currentLang === 'en' ? 'es' : 'en';
      localStorage.setItem('agentx-lang', currentLang);
      applyLang(currentLang);
    }

    /* ── Nav scroll effect ─────────────────────────────────────── */
    const nav = document.getElementById('nav');
    const topbar = document.getElementById('topbar');

    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      topbar.style.width = (scrolled / docH * 100) + '%';
      nav.classList.toggle('scrolled', scrolled > 20);
    }, { passive: true });

    /* ── Scroll-reveal (IntersectionObserver) ──────────────────── */
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .stat-item').forEach(el => revealObserver.observe(el));

    /* ── Mobile nav ────────────────────────────────────────────── */
    function openMobileNav() {
      document.getElementById('mobileNav').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileNav() {
      document.getElementById('mobileNav').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('mobileNavClose').addEventListener('click', closeMobileNav);

    /* ── Init ──────────────────────────────────────────────────── */
    document.addEventListener('DOMContentLoaded', () => {
      applyLang(currentLang);
      document.getElementById('copyright-year').textContent = new Date().getFullYear();

      /* stagger mock-card entrance */
      document.querySelectorAll('.mock-card').forEach((card, i) => {
        card.style.animationDelay = (0.6 + i * 0.12) + 's';
        card.style.animation = 'fadeInUp 0.6s ease both';
        card.style.animationDelay = (0.7 + i * 0.15) + 's';
      });
    });

    /* ── Cursor glow (desktop only) ────────────────────────────── */
    if (window.matchMedia('(pointer: fine)').matches) {
      const glow = document.createElement('div');
      glow.style.cssText = `
        position:fixed; pointer-events:none; z-index:9999;
        width:300px; height:300px; border-radius:50%;
        background:radial-gradient(circle, rgba(124,92,252,0.08) 0%, transparent 70%);
        transform:translate(-50%,-50%);
        transition:left 0.3s ease, top 0.3s ease;
      `;
      document.body.appendChild(glow);
      document.addEventListener('mousemove', e => {
        glow.style.left = e.clientX + 'px';
        glow.style.top  = e.clientY + 'px';
      });
    }
  </script>
</body>
</html>
