<script>
  const MXN_RATE = 17;
  const prices = {
    p1: { setup: 199900, monthly: 49900 },
    p2: { setup: 149900, monthly: 29900 },
    p3: { monthly: 79900 },
    p4: { monthly: 99900 },
    p5: { setup: 249900, monthly: 69900 },
    p6: { setup: 499900, monthly: 129900 }
  };

  function updatePrices(lang) {
    Object.keys(prices).forEach(plan => {
      const p = prices[plan];
      if (p.setup) {
        const setupId = `${plan}-setup-${lang}`;
        const el = document.getElementById(setupId);
        if (el) {
          el.textContent = lang === 'es' 
            ? '$' + (p.setup * MXN_RATE / 100).toLocaleString('es-MX', {minimumFractionDigits: 2, maximumFractionDigits: 2})
            : '$' + (p.setup / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        }
      }
      if (p.monthly) {
        const monthlyId = `${plan}-monthly-${lang}`;
        const el = document.getElementById(monthlyId);
        if (el) {
          el.textContent = lang === 'es'
            ? '$' + (p.monthly * MXN_RATE / 100).toLocaleString('es-MX', {minimumFractionDigits: 2, maximumFractionDigits: 2})
            : '$' + (p.monthly / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        }
      }
    });
  }

  function setLang(lang) {
    document.body.classList.toggle('lang-en', lang === 'en');
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.textContent === lang.toUpperCase());
    });
    updatePrices(lang);
    localStorage.setItem('agentx-lang', lang);
  }

  // Restore saved language preference
  const savedLang = localStorage.getItem('agentx-lang') || 'es';
  updatePrices(savedLang);
  if (savedLang === 'en') setLang('en');
  else setLang('es');

  // Animate result bars on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.width = entry.target.dataset.width || entry.target.style.width;
      }
    });
  }, { threshold: 0.3 });

  // Fade in on scroll
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.solution-card, .result-card, .challenge-item, .tl-item').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    fadeObserver.observe(el);
  });
</script>
</body>
</html>
