      <a href="https://wa.me/525500000000?text=Hola%2C+quiero+automatizar+mi+negocio" target="_blank" class="btn-nav" data-lang="es">Quiero esto →</a>
      <a href="https://wa.me/525500000000?text=Hi%2C+I+want+to+automate+my+business" target="_blank" class="btn-nav" data-lang="en">I want this →</a>
