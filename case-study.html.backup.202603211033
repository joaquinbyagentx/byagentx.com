<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Caso de Estudio: Restaurante La Mesa — AgentX</title>
  <meta name="description" content="+40% pedidos online, atención 24/7 por WhatsApp, -3h de trabajo administrativo al día. Así automatizamos La Mesa, un restaurante en Puebla." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    /* ─── Design Tokens ───────────────────────────────────────────── */
    :root {
      --font: 'Inter', system-ui, -apple-system, sans-serif;
      --bg:           #0a0a0f;
      --bg-2:         #101018;
      --bg-3:         #16161f;
      --border:       rgba(255,255,255,0.07);
      --border-mid:   rgba(255,255,255,0.12);
      --text-1:       #f0f0ff;
      --text-2:       #a0a0b8;
      --text-3:       #606078;
      --accent:       #7c5cfc;
      --accent-2:     #5b8af5;
      --accent-3:     #25d366; /* WhatsApp green */
      --accent-glow:  rgba(124,92,252,0.35);
      --accent-light: rgba(124,92,252,0.12);
      --gradient-hero: linear-gradient(135deg, #7c5cfc 0%, #5b8af5 50%, #38c8ff 100%);
      --gradient-card: linear-gradient(145deg, rgba(124,92,252,0.08) 0%, rgba(91,138,245,0.04) 100%);
      --r-sm: 8px; --r-md: 16px; --r-lg: 24px; --r-xl: 32px;
      --t-fast: 150ms cubic-bezier(0.4,0,0.2,1);
      --t-mid:  300ms cubic-bezier(0.4,0,0.2,1);
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text-1);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-mid); border-radius: 99px; }

    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
    .container-narrow { max-width: 760px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ─── NAV ──────────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 14px 0;
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .nav-brand {
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: -0.02em;
      background: var(--gradient-hero);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-decoration: none;
    }
    .nav-tag {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.75rem;
      color: var(--text-3);
    }
    .nav-tag span {
      padding: 3px 10px;
      border: 1px solid var(--border-mid);
      border-radius: 99px;
      color: var(--text-2);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .nav-cta {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .btn-nav {
      padding: 7px 18px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--r-sm);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: opacity var(--t-fast);
    }
    .btn-nav:hover { opacity: 0.85; }

    /* ─── LANG TOGGLE ──────────────────────────────────────────────── */
    .lang-toggle {
      display: flex;
      align-items: center;
      gap: 2px;
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      padding: 3px;
    }
    .lang-btn {
      padding: 4px 10px;
      font-size: 0.72rem;
      font-weight: 600;
      border-radius: 6px;
      cursor: pointer;
      transition: all var(--t-fast);
      color: var(--text-3);
      background: transparent;
      border: none;
      letter-spacing: 0.04em;
    }
    .lang-btn.active {
      background: var(--accent);
      color: #fff;
    }

    /* ─── HERO ─────────────────────────────────────────────────────── */
    .hero {
      padding: 96px 0 80px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(124,92,252,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 28px;
      font-size: 0.8rem;
      color: var(--text-3);
    }
    .breadcrumb a { color: var(--text-3); text-decoration: none; }
    .breadcrumb a:hover { color: var(--text-2); }
    .breadcrumb-sep { opacity: 0.4; }
    .breadcrumb-current { color: var(--text-2); }

    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border: 1px solid rgba(37,211,102,0.3);
      border-radius: 99px;
      background: rgba(37,211,102,0.08);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent-3);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .hero-label::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent-3);
      box-shadow: 0 0 8px var(--accent-3);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.85); }
    }

    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }
    .hero h1 .gradient-text {
      background: var(--gradient-hero);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 1.15rem;
      color: var(--text-2);
      max-width: 600px;
      line-height: 1.65;
      margin-bottom: 36px;
    }
    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 48px;
      padding-bottom: 40px;
      border-bottom: 1px solid var(--border);
    }
    .hero-meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
      color: var(--text-3);
    }
    .hero-meta-item strong { color: var(--text-2); font-weight: 500; }
    .hero-meta-dot {
      width: 3px; height: 3px;
      background: var(--text-3);
      border-radius: 50%;
    }

    /* ─── HERO METRICS BAND ──────────────────────────────────────── */
    .metrics-band {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: var(--border);
      border-radius: var(--r-lg);
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .metric-cell {
      background: var(--bg-2);
      padding: 32px 28px;
      text-align: center;
      position: relative;
      transition: background var(--t-fast);
    }
    .metric-cell:hover { background: var(--bg-3); }
    .metric-value {
      font-size: 3rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 8px;
    }
    .metric-value.green  { background: linear-gradient(135deg, #25d366, #128c7e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .metric-value.purple { background: var(--gradient-hero); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .metric-value.blue   { background: linear-gradient(135deg, #5b8af5, #38c8ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .metric-label { font-size: 0.82rem; color: var(--text-3); line-height: 1.4; }
    .metric-label strong { display: block; color: var(--text-2); font-size: 0.88rem; margin-bottom: 2px; }

    /* ─── SECTION BASE ─────────────────────────────────────────────── */
    section { padding: 80px 0; }
    .section-label {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 99px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .label-orange { background: rgba(255,140,0,0.12); color: #ff8c00; border: 1px solid rgba(255,140,0,0.25); }
    .label-purple { background: var(--accent-light); color: var(--accent); border: 1px solid rgba(124,92,252,0.25); }
    .label-green  { background: rgba(37,211,102,0.1); color: var(--accent-3); border: 1px solid rgba(37,211,102,0.25); }
    .label-blue   { background: rgba(56,200,255,0.1); color: #38c8ff; border: 1px solid rgba(56,200,255,0.25); }

    h2 {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .section-desc {
      font-size: 1.05rem;
      color: var(--text-2);
      line-height: 1.7;
      max-width: 580px;
    }

    /* ─── DIVIDER ───────────────────────────────────────────────────── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-mid), transparent);
    }

    /* ─── CLIENT PROFILE ────────────────────────────────────────────── */
    .client-profile {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
    }
    .client-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: 32px;
      position: relative;
      overflow: hidden;
    }
    .client-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--gradient-hero);
    }
    .client-avatar {
      width: 72px; height: 72px;
      border-radius: var(--r-md);
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 20px;
    }
    .client-name { font-size: 1.3rem; font-weight: 700; margin-bottom: 4px; }
    .client-location {
      font-size: 0.82rem;
      color: var(--text-3);
      display: flex;
      align-items: center;
      gap: 4px;
      margin-bottom: 20px;
    }
    .client-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .tag {
      padding: 4px 10px;
      border: 1px solid var(--border-mid);
      border-radius: 99px;
      font-size: 0.72rem;
      color: var(--text-2);
    }

    .challenge-list { display: flex; flex-direction: column; gap: 16px; }
    .challenge-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      padding: 18px;
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      transition: border-color var(--t-fast);
    }
    .challenge-item:hover { border-color: var(--border-mid); }
    .challenge-icon {
      width: 36px; height: 36px;
      border-radius: var(--r-sm);
      background: rgba(255,100,100,0.1);
      border: 1px solid rgba(255,100,100,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .challenge-text strong { display: block; font-size: 0.9rem; margin-bottom: 2px; }
    .challenge-text span { font-size: 0.82rem; color: var(--text-3); }

    /* ─── BEFORE/AFTER ─────────────────────────────────────────────── */
    .before-after {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: var(--border);
      border-radius: var(--r-xl);
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .ba-panel {
      padding: 36px 32px;
    }
    .ba-panel.before { background: var(--bg-2); }
    .ba-panel.after  { background: var(--bg-3); }
    .ba-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .ba-dot-red  { width: 8px; height: 8px; border-radius: 50%; background: #ff4444; box-shadow: 0 0 8px rgba(255,68,68,0.5); }
    .ba-dot-green { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-3); box-shadow: 0 0 8px rgba(37,211,102,0.5); }
    .ba-items { display: flex; flex-direction: column; gap: 12px; }
    .ba-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.88rem;
      color: var(--text-2);
    }
    .ba-item::before { content: '—'; color: var(--text-3); flex-shrink: 0; }
    .ba-panel.after .ba-item::before { content: '✓'; color: var(--accent-3); }
    .ba-panel.after .ba-item { color: var(--text-1); }

    /* ─── SOLUTION STEPS ───────────────────────────────────────────── */
    .solution-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 48px;
    }
    .solution-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: 28px;
      position: relative;
      overflow: hidden;
      transition: all var(--t-mid);
    }
    .solution-card:hover {
      border-color: rgba(124,92,252,0.4);
      transform: translateY(-3px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }
    .solution-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient-card);
      opacity: 0;
      transition: opacity var(--t-mid);
    }
    .solution-card:hover::after { opacity: 1; }
    .solution-step {
      font-size: 0.68rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .solution-icon {
      font-size: 2rem;
      margin-bottom: 16px;
      display: block;
    }
    .solution-card h3 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .solution-card p {
      font-size: 0.83rem;
      color: var(--text-2);
      line-height: 1.6;
    }

    /* ─── WHATSAPP MOCKUP ──────────────────────────────────────────── */
    .mockup-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .mockup-phone {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.5);
      position: relative;
    }
    .phone-statusbar {
      background: #075e54;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .phone-back { color: #fff; font-size: 1.1rem; opacity: 0.8; cursor: pointer; }
    .phone-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
    }
    .phone-contact { flex: 1; }
    .phone-contact-name { font-size: 0.9rem; font-weight: 600; color: #fff; }
    .phone-contact-status { font-size: 0.7rem; color: rgba(255,255,255,0.6); }
    .phone-chat {
      background: #0b141a;
      padding: 16px;
      min-height: 320px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .msg {
      max-width: 72%;
      padding: 8px 12px;
      border-radius: 8px;
      font-size: 0.82rem;
      line-height: 1.5;
      position: relative;
    }
    .msg-in {
      background: #202c33;
      color: #e9edef;
      border-radius: 0 8px 8px 8px;
      align-self: flex-start;
    }
    .msg-out {
      background: #005c4b;
      color: #e9edef;
      border-radius: 8px 0 8px 8px;
      align-self: flex-end;
    }
    .msg-time { font-size: 0.65rem; color: rgba(255,255,255,0.4); text-align: right; margin-top: 4px; }
    .msg-typing {
      background: #202c33;
      padding: 12px 16px;
      border-radius: 0 8px 8px 8px;
      display: inline-flex;
      gap: 4px;
      align-self: flex-start;
    }
    .typing-dot {
      width: 6px; height: 6px;
      background: rgba(255,255,255,0.4);
      border-radius: 50%;
      animation: typing 1.2s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typing {
      0%, 60%, 100% { opacity: 0.4; transform: translateY(0); }
      30% { opacity: 1; transform: translateY(-4px); }
    }

    /* ─── RESULTS ──────────────────────────────────────────────────── */
    .results-section { background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .results-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-top: 48px;
    }
    .result-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: 32px;
      position: relative;
      overflow: hidden;
      transition: all var(--t-mid);
    }
    .result-card:hover {
      border-color: var(--border-mid);
      transform: translateY(-2px);
    }
    .result-card.featured {
      grid-column: span 2;
      background: linear-gradient(135deg, rgba(124,92,252,0.12) 0%, rgba(91,138,245,0.06) 100%);
      border-color: rgba(124,92,252,0.3);
    }
    .result-number {
      font-size: 3.5rem;
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 8px;
    }
    .result-number.purple { background: var(--gradient-hero); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .result-number.green  { background: linear-gradient(135deg, #25d366, #128c7e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .result-number.blue   { background: linear-gradient(135deg, #5b8af5, #38c8ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .result-number.orange { background: linear-gradient(135deg, #ff8c00, #ff6b35); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .result-title { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
    .result-desc { font-size: 0.83rem; color: var(--text-3); line-height: 1.5; }
    .result-bar {
      height: 4px;
      background: var(--border);
      border-radius: 99px;
      margin-top: 20px;
      overflow: hidden;
    }
    .result-bar-fill {
      height: 100%;
      border-radius: 99px;
      transition: width 1.5s ease-out;
    }
    .result-bar-fill.purple { background: var(--gradient-hero); }
    .result-bar-fill.green  { background: linear-gradient(90deg, #25d366, #128c7e); }
    .result-bar-fill.blue   { background: linear-gradient(90deg, #5b8af5, #38c8ff); }
    .result-bar-fill.orange { background: linear-gradient(90deg, #ff8c00, #ff6b35); }

    /* Featured result row */
    .featured-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    .featured-metric-num {
      font-size: 2.4rem;
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 6px;
    }
    .featured-metric-label { font-size: 0.82rem; color: var(--text-2); }

    /* ─── TIMELINE ─────────────────────────────────────────────────── */
    .timeline { position: relative; padding-left: 32px; margin-top: 48px; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 10px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: linear-gradient(180deg, var(--accent), transparent);
    }
    .tl-item {
      position: relative;
      margin-bottom: 32px;
    }
    .tl-item::before {
      content: '';
      position: absolute;
      left: -26px;
      top: 4px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent-glow);
    }
    .tl-date {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .tl-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
    .tl-desc { font-size: 0.83rem; color: var(--text-3); }

    /* ─── TESTIMONIAL ──────────────────────────────────────────────── */
    .testimonial-block {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: 48px;
      position: relative;
      margin-top: 60px;
    }
    .testimonial-block::before {
      content: '"';
      position: absolute;
      top: 24px; left: 36px;
      font-size: 6rem;
      line-height: 1;
      color: var(--accent);
      opacity: 0.25;
      font-family: Georgia, serif;
    }
    .testimonial-quote {
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.65;
      color: var(--text-1);
      margin-bottom: 28px;
      position: relative;
      z-index: 1;
    }
    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .author-avatar {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .author-name { font-size: 0.9rem; font-weight: 700; }
    .author-role { font-size: 0.78rem; color: var(--text-3); }
    .stars {
      margin-left: auto;
      color: #ffd700;
      font-size: 1rem;
      letter-spacing: 2px;
    }

    /* ─── PRICING SECTION ──────────────────────────────────────────── */
    .pricing-section { text-align: center; }
    .pricing-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 48px;
      text-align: left;
    }
    .pricing-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: 32px;
      position: relative;
      overflow: hidden;
      transition: all var(--t-mid);
    }
    .pricing-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
    .pricing-card.popular {
      border-color: rgba(124,92,252,0.5);
      background: linear-gradient(145deg, rgba(124,92,252,0.1), rgba(91,138,245,0.05));
    }
    .popular-badge {
      display: inline-block;
      padding: 4px 12px;
      background: var(--accent);
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 99px;
      margin-bottom: 20px;
    }
    .pricing-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
    .pricing-price {
      font-size: 2.4rem;
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 4px;
    }
    .pricing-price span { font-size: 1rem; font-weight: 500; color: var(--text-3); }
    .pricing-period { font-size: 0.78rem; color: var(--text-3); margin-bottom: 24px; }
    .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
    .pricing-features li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.85rem;
      color: var(--text-2);
    }
    .pricing-features li::before { content: '✓'; color: var(--accent-3); font-weight: 700; flex-shrink: 0; }
    .btn-pricing {
      display: block;
      width: 100%;
      padding: 12px;
      border-radius: var(--r-md);
      font-size: 0.88rem;
      font-weight: 700;
      text-align: center;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--t-fast);
      border: none;
    }
    .btn-pricing-outline {
      background: transparent;
      border: 1px solid var(--border-mid);
      color: var(--text-1);
    }
    .btn-pricing-outline:hover { border-color: var(--accent); color: var(--accent); }
    .btn-pricing-filled {
      background: var(--accent);
      color: #fff;
    }
    .btn-pricing-filled:hover { opacity: 0.88; }

    /* ─── CTA SECTION ──────────────────────────────────────────────── */
    .cta-section {
      padding: 100px 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-section::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 400px;
      background: radial-gradient(ellipse, rgba(124,92,252,0.2) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-section h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      max-width: 640px;
      margin: 0 auto 20px;
    }
    .cta-section p {
      font-size: 1.05rem;
      color: var(--text-2);
      max-width: 480px;
      margin: 0 auto 40px;
    }
    .cta-buttons {
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--r-md);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--t-fast);
      box-shadow: 0 4px 20px var(--accent-glow);
    }
    .btn-primary:hover {
      opacity: 0.88;
      transform: translateY(-1px);
      box-shadow: 0 6px 30px var(--accent-glow);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      background: transparent;
      color: var(--text-1);
      border: 1px solid var(--border-mid);
      border-radius: var(--r-md);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--t-fast);
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
    .cta-trust {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-top: 32px;
      flex-wrap: wrap;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: var(--text-3);
    }
    .trust-icon { font-size: 0.9rem; }

    /* ─── FOOTER ───────────────────────────────────────────────────── */
    footer {
      padding: 40px 0;
      border-top: 1px solid var(--border);
    }
    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-brand {
      font-weight: 800;
      background: var(--gradient-hero);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a { font-size: 0.82rem; color: var(--text-3); text-decoration: none; }
    .footer-links a:hover { color: var(--text-2); }
    .footer-copy { font-size: 0.78rem; color: var(--text-3); }

    /* ─── LANG SECTIONS ────────────────────────────────────────────── */
    [data-lang="en"] { display: none; }
    body.lang-en [data-lang="es"] { display: none; }
    body.lang-en [data-lang="en"] { display: block; }
    /* For inline elements that need display:flex or display:inline-flex */
    .inline-lang[data-lang="en"] { display: none; }
    body.lang-en .inline-lang[data-lang="es"] { display: none; }
    body.lang-en .inline-lang[data-lang="en"] { display: inline-flex; }

    /* ─── RESPONSIVE ───────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .metrics-band,
      .before-after,
      .solution-grid,
      .results-grid,
      .mockup-section,
      .client-profile,
      .pricing-cards,
      .featured-metrics { grid-template-columns: 1fr; }
      .result-card.featured { grid-column: span 1; }
      .nav-tag { display: none; }
      h2 { font-size: 1.6rem; }
      .hero h1 { font-size: 2rem; }
      .metric-value { font-size: 2.2rem; }
      .testimonial-block { padding: 28px; }
      .testimonial-quote { font-size: 1rem; }
      .hero { padding: 60px 0 50px; }
      section { padding: 60px 0; }
    }
  </style>
</head>
<body>

<!-- ─── NAV ─────────────────────────────────────────────────────── -->
<nav>
  <div class="nav-inner">
    <a href="https://byagentx.com" class="nav-brand">AgentX</a>
